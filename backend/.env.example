# 万语风 (PolyWind) 环境变量配置
# 复制此文件为 .env 并填入你的配置

# 运行环境: development / staging / production
POLYWIND_ENV=development

# LLM配置（通义千问Qwen3，支持100+语言）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen-plus

# 或使用自定义API端点
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://your-api-endpoint.com/v1

# 和风天气API（中文灾害预警）
QWEATHER_API_KEY=your_qweather_key_here

# Open-Meteo Air Quality API（空气质量，免费无需 key）
# OPEN_METEO_AQ_BASE_URL=https://air-quality-api.open-meteo.com/v1
# OPEN_METEO_AQ_TIMEOUT=10.0

# Redis（缓存，可选）
REDIS_URL=redis://localhost:6379/0

# CORS（生产环境必须配置）
# CORS_ORIGINS=https://your-domain.com

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true
